a schema:CreativeWork ;
schema:name "Annual Aboriginal Census,1921-1944 - Western Australia"@en ;
schema:description "This study contains time series of data of the Annual Aboriginal Census for Australia, Australian Capital Territory, New South Wales, Northern Territory, Queensland, South Australia, Tasmania, Victoria and Western Australia from 1921 to 1944. The file au.edu.anu.ada.ddi.20002-wa is the data for the Western Australia."@en ;
schema:keywords idnth:indigenous-demographics ;
schema:additionalType dataIndig:about-indigenous-people ;
schema:dateCreated "2026-05-26"^^xsd:date ;
schema:dateModified "2026-05-26"^^xsd:date ;
